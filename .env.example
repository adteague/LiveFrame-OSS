# Required: Your Google Gemini API key
# Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-api-key-here

# Optional: Override defaults (uncomment to use)
# LIVEFRAME_GEMINI_MODEL=gemini-2.5-flash       # gemini-2.5-flash | gemini-2.5-pro | gemini-2.0-flash-lite
# LIVEFRAME_ANALYSIS_MODE=fast                   # fast (~2.5h/chunk, cheaper) | detailed (~52min/chunk)
# LIVEFRAME_TARGET_CLIPS_PER_HOUR=2.5
# LIVEFRAME_MIN_CLIP_SECONDS=15
# LIVEFRAME_MARGIN_SECONDS=3.0
# LIVEFRAME_ACCURATE_CUTS=false
# LIVEFRAME_ANALYSIS_FPS=2
# LIVEFRAME_DOWNSCALE_FOR_ANALYSIS=false

# Optional: For auto-captions with OpenAI Whisper API (instead of local model)
# LIVEFRAME_OPENAI_API_KEY=sk-...

# Optional: For speaker diarization (requires pyannote.audio)
# LIVEFRAME_HF_TOKEN=hf_...
